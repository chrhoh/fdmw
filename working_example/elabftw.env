# MySQL configuration
DB_HOST: "pxc1"
DB_PORT: 3306
DB_NAME: "elabftw"
DB_USER: "elabftw"
DB_PASSWORD: "secret"

# PHP configuration
PHP_TIMEZONE: "Europe/Berlin"
TZ: "Europe/Berlin"
PHP_MAX_CHILDREN: 60
PHP_MAX_EXECUTION_TIME: 180
MAX_PHP_MEMORY: "2G"

# eLabFTW configuration
SECRET_KEY: "secret"
SITE_URL: "https://elabftw.dus"
MAX_UPLOAD_SIZE: "100M"
STATUS_PASSWORD: "secret"
ELAB_AWS_ACCESS_KEY: "xxx"
ELAB_AWS_SECRET_KEY: "xxxx"

# Nginx Configuration
SERVER_NAME: "elabftw.dus"
DISABLE_HTTPS: true
ENABLE_LETSENCRYPT: false
ENABLE_IPV6: false
ELABFTW_USER: "nginx"
ELABFTW_GROUP: "nginx"
ELABFTW_USERID: 501
ELABFTW_GROUPID: 501

SET_REAL_IP: true
SET_REAL_IP_FROM: "127.0.0.1"
NGINX_WORK_PROC: "auto"
KEEPALIVE_TIMEOUT: "100s"

# Redis configuration
USE_REDIS: true
REDIS_HOST: "redis"
REDIS_PORT: 6379

# Plugins
## Chen
USE_INDIGO: true
INDIGO_URL: "http://chem-plugin/"
USE_FINGERPRINTER: true
FINGERPRINTER_URL: "http://chem-plugin:8000"

## Open cloning
USE_OPENCLONING: true
OPENCLONING_URL: "http://opencloning-plugin:8000"